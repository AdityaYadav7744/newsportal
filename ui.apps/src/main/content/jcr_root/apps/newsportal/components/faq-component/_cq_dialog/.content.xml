<?xml version="1.0" encoding="UTF-8"?>
<jcr:root xmlns:jcr="http://www.jcp.org/jcr/1.0" xmlns:nt="http://www.jcp.org/jcr/nt/1.0" xmlns:granite="http://www.adobe.com/jcr/granite/1.0" xmlns:cq="http://www.day.com/jcr/cq/1.0" xmlns:sling="http://sling.apache.org/jcr/sling/1.0"
    jcr:primaryType="nt:unstructured"
    jcr:title="Properties"
    sling:resourceType="cq/gui/components/authoring/dialog"
    extraClientlibs="[dialog.clientlibs]">
    <content
        jcr:primaryType="nt:unstructured"
        sling:resourceType="granite/ui/components/coral/foundation/container">
        <items jcr:primaryType="nt:unstructured">
            <tabs
                jcr:primaryType="nt:unstructured"
                sling:resourceType="granite/ui/components/coral/foundation/tabs">
                <items jcr:primaryType="nt:unstructured">
                    <properties
                        jcr:primaryType="nt:unstructured"
                        jcr:title="Properties"
                        sling:resourceType="granite/ui/components/coral/foundation/container">
                        <items jcr:primaryType="nt:unstructured">
                            <disableLazyLoading
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="granite/ui/components/coral/foundation/form/checkbox"
                                name="./disableLazyLoading"
                                text="Disable lazy loading"
                                uncheckedValue="{Boolean}false"
                                value="{Boolean}true"/>
                            <cardType
                                granite:class="cq-dialog-dropdown-showhide cq-dialog-cardtype-select"
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="granite/ui/components/coral/foundation/form/select"
                                emptyOption="{Boolean}false"
                                fieldLabel="Card Type"
                                name="./cardType">
                                <granite:data
                                    jcr:primaryType="nt:unstructured"
                                    cq-dialog-dropdown-showhide-target=".cardtype-showhide-target"/>
                                <items jcr:primaryType="nt:unstructured">
                                    <manual
                                        jcr:primaryType="nt:unstructured"
                                        selected="{Boolean}true"
                                        text="Manual"
                                        value="manual"/>
                                    <dynamic
                                        jcr:primaryType="nt:unstructured"
                                        text="Dynamic"
                                        value="dynamic"/>
                                </items>
                            </cardType>
                            <showAsCarousel
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="granite/ui/components/coral/foundation/form/checkbox"
                                name="./showAsCarousel"
                                text="Show as carousel"
                                uncheckedValue="{Boolean}false"
                                value="{Boolean}true"/>
                            <cardCount
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="granite/ui/components/coral/foundation/form/numberfield"
                                fieldDescription="Enter the number of cards to display"
                                fieldLabel="Card Count"
                                max="{Long}20"
                                min="{Long}1"
                                name="./cardCount"
                                value="{Long}4"/>
                        </items>
                    </properties>
                    <cardDetails
                        granite:class="cq-dialog-second-tab"
                        jcr:primaryType="nt:unstructured"
                        jcr:title="Manual"
                        sling:resourceType="granite/ui/components/coral/foundation/container">
                        <items jcr:primaryType="nt:unstructured">
                            <manualFields
                                granite:class="cardtype-showhide-target"
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="granite/ui/components/coral/foundation/container">
                                <granite:data
                                    jcr:primaryType="nt:unstructured"
                                    showhidetargetvalue="manual"/>
                                <items jcr:primaryType="nt:unstructured">
                                    <manualCards
                                        jcr:primaryType="nt:unstructured"
                                        sling:resourceType="granite/ui/components/coral/foundation/form/multifield"
                                        composite="{Boolean}true"
                                        fieldLabel="Manual Cards">
                                        <field
                                            jcr:primaryType="nt:unstructured"
                                            sling:resourceType="granite/ui/components/coral/foundation/container"
                                            name="./manualCards">
                                            <items jcr:primaryType="nt:unstructured">
                                                <cardTitle
                                                    jcr:primaryType="nt:unstructured"
                                                    sling:resourceType="granite/ui/components/coral/foundation/form/textfield"
                                                    fieldLabel="Card Title"
                                                    name="./cardTitle"/>
                                                <cardImage
                                                    jcr:primaryType="nt:unstructured"
                                                    sling:resourceType="granite/ui/components/coral/foundation/form/pathfield"
                                                    fieldLabel="Card Image"
                                                    name="./cardImage"
                                                    rootPath="/content/dam"/>
                                                <shortDescription
                                                    jcr:primaryType="nt:unstructured"
                                                    sling:resourceType="granite/ui/components/coral/foundation/form/textarea"
                                                    fieldLabel="Short Description"
                                                    name="./shortDescription"/>
                                                <fullDescription
                                                    jcr:primaryType="nt:unstructured"
                                                    sling:resourceType="granite/ui/components/coral/foundation/form/textarea"
                                                    fieldLabel="Full Description"
                                                    name="./fullDescription"/>
                                                <ctaText
                                                    jcr:primaryType="nt:unstructured"
                                                    sling:resourceType="granite/ui/components/coral/foundation/form/textfield"
                                                    fieldLabel="CTA Text"
                                                    name="./ctaText"
                                                    rootPath="/content"/>
                                                <ctaLink
                                                    jcr:primaryType="nt:unstructured"
                                                    sling:resourceType="granite/ui/components/coral/foundation/form/pathfield"
                                                    fieldLabel="CTA Link"
                                                    name="./ctaLink"
                                                    rootPath="/content"/>
                                            </items>
                                        </field>
                                    </manualCards>
                                </items>
                            </manualFields>
                            <dynamicFields
                                granite:class="hide cardtype-showhide-target"
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="granite/ui/components/coral/foundation/container">
                                <granite:data
                                    jcr:primaryType="nt:unstructured"
                                    showhidetargetvalue="dynamic"/>
                                <items jcr:primaryType="nt:unstructured">
                                    <rootPath
                                        jcr:primaryType="nt:unstructured"
                                        sling:resourceType="granite/ui/components/coral/foundation/form/pathfield"
                                        fieldLabel="Root Path"
                                        name="./rootPath"
                                        rootPath="/content"/>
                                    <clickAction
                                        jcr:primaryType="nt:unstructured"
                                        sling:resourceType="granite/ui/components/coral/foundation/form/select"
                                        fieldLabel="Click Action"
                                        name="./clickAction">
                                        <items jcr:primaryType="nt:unstructured">
                                            <overlay
                                                jcr:primaryType="nt:unstructured"
                                                selected="{Boolean}true"
                                                text="Overlay"
                                                value="overlay"/>
                                            <redirect
                                                jcr:primaryType="nt:unstructured"
                                                text="Redirect"
                                                value="redirect"/>
                                        </items>
                                    </clickAction>
                                </items>
                            </dynamicFields>
                        </items>
                    </cardDetails>
                </items>
            </tabs>
        </items>
    </content>
</jcr:root>
