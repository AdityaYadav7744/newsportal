<?xml version="1.0" encoding="UTF-8"?>
<jcr:root xmlns:jcr="http://www.jcp.org/jcr/1.0" xmlns:nt="http://www.jcp.org/jcr/nt/1.0" xmlns:cq="http://www.day.com/jcr/cq/1.0" xmlns:sling="http://sling.apache.org/jcr/sling/1.0"
    jcr:primaryType="nt:unstructured"
    jcr:title="Product Details"
    sling:resourceType="cq/gui/components/authoring/dialog">
    <content
        jcr:primaryType="nt:unstructured"
        sling:resourceType="granite/ui/components/coral/foundation/container">
        <items jcr:primaryType="nt:unstructured">
            <tabs
                jcr:primaryType="nt:unstructured"
                sling:resourceType="granite/ui/components/coral/foundation/tabs">
                <items jcr:primaryType="nt:unstructured">
                    <dialogProducts
                        jcr:primaryType="nt:unstructured"
                        jcr:title="Product Cards"
                        sling:resourceType="granite/ui/components/coral/foundation/container">
                        <items jcr:primaryType="nt:unstructured">
                            <products
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="granite/ui/components/coral/foundation/form/multifield"
                                composite="{Boolean}true"
                                fieldLabel="Products">
                                <field
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="granite/ui/components/coral/foundation/container"
                                    name="./products">
                                    <items jcr:primaryType="nt:unstructured">
                                        <accordion
                                            jcr:primaryType="nt:unstructured"
                                            sling:resourceType="granite/ui/components/coral/foundation/accordion"
                                            parentConfig="{Boolean}true">
                                            <items jcr:primaryType="nt:unstructured">
                                                <product
                                                    jcr:primaryType="nt:unstructured"
                                                    jcr:title="Product"
                                                    sling:resourceType="granite/ui/components/coral/foundation/container">
                                                    <items jcr:primaryType="nt:unstructured">
                                                        <productTitle
                                                            jcr:primaryType="nt:unstructured"
                                                            sling:resourceType="granite/ui/components/coral/foundation/form/textfield"
                                                            fieldLabel="Product Title"
                                                            name="./ProductTitle"/>
                                                        <productExpiry
                                                            jcr:primaryType="nt:unstructured"
                                                            sling:resourceType="granite/ui/components/coral/foundation/form/datepicker"
                                                            fieldLabel="Product Expiry Date"
                                                            name="./productExpiry"/>
                                                        <productPrice
                                                            jcr:primaryType="nt:unstructured"
                                                            sling:resourceType="granite/ui/components/coral/foundation/form/numberfield"
                                                            fieldLabel="Product Price"
                                                            name="./productprice"/>
                                                        <productImage
                                                            jcr:primaryType="nt:unstructured"
                                                            sling:resourceType="granite/ui/components/coral/foundation/form/pathfield"
                                                            fieldLabel="Product Image"
                                                            name="./productImage"
                                                            rootPath="/content/dam"/>
                                                        <productColor
                                                            jcr:primaryType="nt:unstructured"
                                                            sling:resourceType="granite/ui/components/coral/foundation/form/colorfield"
                                                            fieldLabel="Product Color"
                                                            name="./productColor"/>
                                                        <productTag
                                                            jcr:primaryType="nt:unstructured"
                                                            sling:resourceType="cq/gui/components/coral/common/form/tagfield"
                                                            fieldLabel="Product Tag"
                                                            name="./productTag"/>
                                                    </items>
                                                </product>
                                            </items>
                                        </accordion>
                                    </items>
                                </field>
                            </products>
                            <loadFromCF
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="granite/ui/components/coral/foundation/form/checkbox"
                                name="./loadFromCF"
                                text="Load Products From Content Fragment"
                                value="{Boolean}true"/>
                            <cfProductPaths
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="granite/ui/components/coral/foundation/form/multifield"
                                fieldLabel="Content Fragment Paths">
                                <field
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="granite/ui/components/coral/foundation/form/pathfield"
                                    fieldLabel="Content Fragment Path"
                                    name="./cfProductPaths"
                                    rootPath="/content/dam"/>
                            </cfProductPaths>
                        </items>
                    </dialogProducts>
                    <general
                        jcr:primaryType="nt:unstructured"
                        jcr:title="General"
                        sling:resourceType="granite/ui/components/coral/foundation/container">
                        <items jcr:primaryType="nt:unstructured">
                            <title
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="granite/ui/components/coral/foundation/form/textfield"
                                fieldLabel="Title"
                                name="./title"/>
                            <description
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="cq/gui/components/authoring/dialog/richtext"
                                fieldLabel="Description"
                                name="./description"
                                useFixedInlineToolbar="{Boolean}true"/>
                            <status
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="granite/ui/components/coral/foundation/form/checkbox"
                                name="./status"
                                text="Status"
                                uncheckedValue="{Boolean}false"
                                value="{Boolean}true"/>
                            <category
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="granite/ui/components/coral/foundation/form/select"
                                fieldLabel="Category"
                                name="./category">
                                <items jcr:primaryType="nt:unstructured">
                                    <kids
                                        jcr:primaryType="nt:unstructured"
                                        text="Kids"
                                        value="kids"/>
                                    <men
                                        jcr:primaryType="nt:unstructured"
                                        text="Men"
                                        value="men"/>
                                    <women
                                        jcr:primaryType="nt:unstructured"
                                        text="Women"
                                        value="women"/>
                                </items>
                            </category>
                        </items>
                    </general>
                    <productCards
                        jcr:primaryType="nt:unstructured"
                        jcr:title="Product Cards"
                        sling:resourceType="granite/ui/components/coral/foundation/container">
                        <items jcr:primaryType="nt:unstructured">
                            <products
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="granite/ui/components/coral/foundation/form/multifield"
                                composite="{Boolean}true"
                                fieldLabel="Products">
                                <field
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="granite/ui/components/coral/foundation/container"
                                    name="./products">
                                    <items jcr:primaryType="nt:unstructured">
                                        <accordion
                                            jcr:primaryType="nt:unstructured"
                                            sling:resourceType="granite/ui/components/coral/foundation/accordion"
                                            parentConfig="{Boolean}true">
                                            <items jcr:primaryType="nt:unstructured">
                                                <product
                                                    jcr:primaryType="nt:unstructured"
                                                    jcr:title="Product"
                                                    sling:resourceType="granite/ui/components/coral/foundation/container">
                                                    <items jcr:primaryType="nt:unstructured">
                                                        <productTitle
                                                            jcr:primaryType="nt:unstructured"
                                                            sling:resourceType="granite/ui/components/coral/foundation/form/textfield"
                                                            fieldLabel="Product Title"
                                                            name="./productName"/>
                                                        <productExpiry
                                                            jcr:primaryType="nt:unstructured"
                                                            sling:resourceType="granite/ui/components/coral/foundation/form/datepicker"
                                                            fieldLabel="Product Expiry Date"
                                                            name="./expiryDate"/>
                                                        <productPrice
                                                            jcr:primaryType="nt:unstructured"
                                                            sling:resourceType="granite/ui/components/coral/foundation/form/numberfield"
                                                            fieldLabel="Product Price"
                                                            name="./price"/>
                                                        <productImage
                                                            jcr:primaryType="nt:unstructured"
                                                            sling:resourceType="granite/ui/components/coral/foundation/form/pathfield"
                                                            fieldLabel="Product Image"
                                                            name="./image"
                                                            rootPath="/content/dam"/>
                                                        <productColor
                                                            jcr:primaryType="nt:unstructured"
                                                            sling:resourceType="granite/ui/components/coral/foundation/form/colorfield"
                                                            fieldLabel="Product Color"
                                                            name="./productColor"/>
                                                        <productTag
                                                            jcr:primaryType="nt:unstructured"
                                                            sling:resourceType="cq/gui/components/coral/common/form/tagfield"
                                                            fieldLabel="Product Tag"
                                                            name="./productTag"/>
                                                    </items>
                                                </product>
                                            </items>
                                        </accordion>
                                        <productName
                                            jcr:primaryType="nt:unstructured"
                                            sling:resourceType="granite/ui/components/coral/foundation/form/textfield"
                                            fieldLabel="Product Name"
                                            name="./productName"/>
                                        <expiryDate
                                            jcr:primaryType="nt:unstructured"
                                            sling:resourceType="granite/ui/components/coral/foundation/form/datepicker"
                                            fieldLabel="Expiry Date"
                                            name="./expiryDate"/>
                                        <price
                                            jcr:primaryType="nt:unstructured"
                                            sling:resourceType="granite/ui/components/coral/foundation/form/numberfield"
                                            fieldLabel="Price"
                                            name="./price"/>
                                        <image
                                            jcr:primaryType="nt:unstructured"
                                            sling:resourceType="granite/ui/components/coral/foundation/form/pathfield"
                                            fieldLabel="Product Image"
                                            name="./image"
                                            rootPath="/content/dam"/>
                                        <productColor
                                            jcr:primaryType="nt:unstructured"
                                            sling:resourceType="granite/ui/components/coral/foundation/form/colorfield"
                                            fieldLabel="Product Color"
                                            name="./productColor"/>
                                        <productTag
                                            jcr:primaryType="nt:unstructured"
                                            sling:resourceType="cq/gui/components/coral/common/form/tagfield"
                                            fieldLabel="Product Tag"
                                            name="./productTag"/>
                                    </items>
                                </field>
                            </products>
                            <loadFromCF
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="granite/ui/components/coral/foundation/form/checkbox"
                                name="./loadFromCF"
                                text="Load Products From Content Fragment"
                                uncheckedValue="{Boolean}false"
                                value="{Boolean}true"/>
                            <cfProductPaths
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="granite/ui/components/coral/foundation/form/multifield"
                                fieldLabel="Content Fragment Paths">
                                <field
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="granite/ui/components/coral/foundation/form/pathfield"
                                    fieldLabel="Content Fragment Path"
                                    filter="dam:Asset"
                                    name="./cfProductPaths"
                                    rootPath="/content/dam"/>
                            </cfProductPaths>
                        </items>
                    </productCards>
                </items>
            </tabs>
        </items>
    </content>
</jcr:root>
