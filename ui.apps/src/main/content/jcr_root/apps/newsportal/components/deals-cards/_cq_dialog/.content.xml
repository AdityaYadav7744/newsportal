<?xml version="1.0" encoding="UTF-8"?>
<jcr:root xmlns:jcr="http://www.jcp.org/jcr/1.0" xmlns:nt="http://www.jcp.org/jcr/nt/1.0" xmlns:cq="http://www.day.com/jcr/cq/1.0" xmlns:sling="http://sling.apache.org/jcr/sling/1.0"
    jcr:primaryType="nt:unstructured"
    jcr:title="Properties"
    sling:resourceType="cq/gui/components/authoring/dialog">
    <content
        jcr:primaryType="nt:unstructured"
        sling:resourceType="granite/ui/components/coral/foundation/fixedcolumns">
        <items jcr:primaryType="nt:unstructured">
            <tabs
                jcr:primaryType="nt:unstructured"
                sling:resourceType="granite/ui/components/coral/foundation/tabs">
                <items jcr:primaryType="nt:unstructured">
                    <dealSelectionTab
                        jcr:primaryType="nt:unstructured"
                        jcr:title="Deal Selection"
                        sling:resourceType="granite/ui/components/coral/foundation/container">
                        <items jcr:primaryType="nt:unstructured">
                            <selectedDeal
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="granite/ui/components/coral/foundation/form/select"
                                fieldLabel="Select Deal"
                                name="./selectedDeal">
                                <datasource
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="newsportal/cards/datasource/deals"/>
                            </selectedDeal>
                        </items>
                    </dealSelectionTab>
                    <cardDetailsTab
                        jcr:primaryType="nt:unstructured"
                        jcr:title="Card Details"
                        sling:resourceType="granite/ui/components/coral/foundation/container">
                        <items jcr:primaryType="nt:unstructured">
                            <cardTitle
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="granite/ui/components/coral/foundation/form/textfield"
                                fieldLabel="Card Title"
                                name="./cardTitle"/>
                            <cardDescription
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="granite/ui/components/coral/foundation/form/textarea"
                                fieldLabel="Card Description"
                                name="./cardDescription"/>
                            <cardImage
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="cq/gui/components/authoring/dialog/fileupload"
                                allowUpload="{Boolean}false"
                                autoStart="{Boolean}false"
                                fieldLabel="Card Image"
                                fileNameParameter="./cardImageName"
                                fileReferenceParameter="./cardImageReference"
                                mimeTypes="[image/*]"
                                name="./cardImage"/>
                        </items>
                    </cardDetailsTab>
                </items>
            </tabs>
        </items>
    </content>
</jcr:root>
